# Google Serper API Configuration (required for web search)
SERPER_API_KEY=your-serper-api-key-here

# LLM Provider API Keys (optional; never store these in the browser UI)
# At least one is required if not using local server
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=

# Local LLM Server Configuration (optional)
VLLM_URL=http://localhost:1234/v1
MODEL_NAME=your-model-name

# Backend Server Configuration (optional)
BACKEND_PORT=8088
BACKEND_HOST=0.0.0.0
FRONTEND_ORIGINS=http://localhost:3000

# Research source reader controls (optional)
SOURCE_READER_MAX_SOURCES=5
SOURCE_READER_MAX_CHARS=400000
SOURCE_READER_TIMEOUT_SECONDS=6
SOURCE_READER_FALLBACK_SOURCES=3
SOURCE_READER_CACHE_TTL_SECONDS=1800
SEARCH_CACHE_TTL_SECONDS=300

# Next.js API route to backend URL (optional, for deployment)
# BACKEND_URL=http://localhost:8088
